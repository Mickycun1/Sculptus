PORT=8787
# Leave blank for local in-memory token storage.
# Set this for persistent WHOOP tokens, for example:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/
MONGODB_URI=
MONGODB_DB=sculptus
SCULPTUS_USER_KEY=local-user
SCULPTUS_ALLOW_LOCAL_AUTH=true
AUTH_SESSION_DAYS=30

GOOGLE_WEB_CLIENT_ID=

WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://127.0.0.1:8787/api/whoop/callback
